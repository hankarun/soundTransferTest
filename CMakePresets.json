{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "msvc",
      "displayName": "Qt 5.15 MSVC 2019 64-bit",
      "description": "Builds with Visual Studio 2022 (x64) against the Qt 5.15.2 MSVC kit",
      "generator": "Visual Studio 17 2022",
      "architecture": { "value": "x64", "strategy": "set" },
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "C:/Qt/5.15.2/msvc2019_64",
        "CMAKE_VS_GLOBALS": "VcpkgEnabled=false;VcpkgApplocalDeps=false"
      },
      "environment": {
        "PATH": "C:/Qt/5.15.2/msvc2019_64/bin;$penv{PATH}"
      }
    }
  ],
  "buildPresets": [
    { "name": "msvc", "configurePreset": "msvc", "configuration": "Release" }
  ],
  "testPresets": [
    {
      "name": "msvc",
      "configurePreset": "msvc",
      "configuration": "Release",
      "output": { "outputOnFailure": true }
    }
  ]
}
